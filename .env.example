# --- LLM (Groq, free 14.4k req/day) ---
GROQ_API_KEY=your_groq_key_here

# --- Embeddings (free tiers) ---
# Provider switch: "gemini" (primary) or "jina" (fallback). Switching requires re-indexing the corpus.
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=1536
JINA_API_KEY=your_jina_key_here
JINA_MODEL=jina-embeddings-v3

# --- Vector store: "chroma" (local/dev) or "qdrant" (cloud) ---
VECTOR_BACKEND=chroma
QDRANT_URL=
QDRANT_API_KEY=

# --- Supabase (metadata DB + Auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

LOG_LEVEL=INFO
SCHEDULE_INTERVAL_HOURS=24
DATA_DIR=./data
